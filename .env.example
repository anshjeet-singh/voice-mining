# Database (TiDB Cloud Serverless or any MySQL)
DATABASE_URL=mysql://user:password@host:4000/voicemining?ssl={"rejectUnauthorized":true}

# Sessions (openssl rand -hex 32)
SESSION_SECRET=

# Google sign-in (Google Cloud Console -> Credentials -> OAuth client ID, type Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI provider: gemini (default, free tier) or anthropic
LLM_PROVIDER=gemini
# Gemini (aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Anthropic (only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Scrapers (Reddit, Hacker News, DuckDuckGo, Trustpilot need NO keys)
# Optional: Reddit OAuth app (reddit.com/prefs/apps, type 'script') makes Reddit
# scraping bulletproof from cloud IPs. Without it we use the public JSON API.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
SERP_API_KEY=
YOUTUBE_API_KEY=
NEWS_API_KEY=
TWITTER_BEARER_TOKEN=

# Weekly trend cron shared secret (openssl rand -hex 24)
CRON_SECRET=

# Optional
ADMIN_EMAIL=
NOTIFY_WEBHOOK_URL=

# Client OS local worker (openssl rand -hex 24; must match Render's WORKER_SECRET)
WORKER_SECRET=
# Worker-only vars (used by `npm run worker` on your Mac, not by the server):
# APP_URL=https://voice-mining.onrender.com
# SKILLS_DIR=/path/to/claude.ai/skills-cache/skills
# LEARNINGS_DIR defaults to <repo>/worker/learnings
